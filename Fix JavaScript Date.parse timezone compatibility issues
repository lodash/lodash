  if (!match) {
    // Not an ISO 8601 string, use original parse
    return originalParse(dateString);
  }
  const [, year, month, day, hours = '00', minutes = '00', seconds = '00', milliseconds = '000', timezone] = match;
  // If timezone is specified, use original parse
  if (timezone || dateString.endsWith('Z') || dateString.endsWith('z')) {
    return originalParse(dateString);
  }
  // No timezone specified, parse as UTC
  const utcString = \`\${year}-\${month}-\${day}T\${hours}:\${minutes}:\${seconds}.\${milliseconds.padEnd(3, '0').slice(0, 3)}Z\`;
  return originalParse(utcString);
};
module.exports = Date.parse;
`;
